{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "x-vercel-ip-country",
          "value": "KR"
        }
      ],
      "destination": "/ko",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "/en",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/ko",
      "destination": "/ko/index.html"
    },
    {
      "source": "/en",
      "destination": "/en/index.html"
    }
  ]
}
